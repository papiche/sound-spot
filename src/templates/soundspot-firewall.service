[Unit]
Description=SoundSpot — Pare-feu (iptables + portail captif)
After=ipset-soundspot.service uap0.service
Requires=ipset-soundspot.service uap0.service
Before=hostapd.service dnsmasq.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/soundspot/soundspot-firewall.sh
ExecStop=/sbin/iptables -F FORWARD
StandardOutput=journal

[Install]
WantedBy=multi-user.target
