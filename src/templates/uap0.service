[Unit]
Description=Interface virtuelle WiFi AP (uap0)
After=network.target
# On attend que wlan0 soit prêt mais pas forcément connecté
BindsTo=sys-subsystem-net-devices-wlan0.device

[Service]
Type=oneshot
# 0. Nettoyer une éventuelle interface uap0 orpheline (reboot chaud, crash)
ExecStartPre=-/sbin/iw dev uap0 del
# 1. Créer l'interface
ExecStartPre=/sbin/iw dev wlan0 interface add uap0 type __ap
# 2. Dériver la MAC de uap0 depuis wlan0 (bit locally-administered) — unique par RPi.
#    set -- décompose la MAC en $1..$6 (pas de $IDENT = pas de substitution systemd).
ExecStartPre=/bin/bash -c 'set -- $(tr : " " < /sys/class/net/wlan0/address); ip link set dev uap0 address $(printf "%02x" $(( (16#$1 | 2) & 254 ))):$2:$3:$4:$5:$6'
# 3. Monter l'interface
ExecStart=/sbin/ip link set dev uap0 up
ExecStop=-/sbin/iw dev uap0 del
RemainAfterExit=yes
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target