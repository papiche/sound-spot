# SoundSpot — configuration centrale
# Modifiable sans relancer le script d'installation

SPOT_NAME="${SPOT_NAME}"
SPOT_IP="${SPOT_IP}"
WIFI_SSID="${WIFI_SSID}"
WIFI_CHANNEL="${WIFI_CHANNEL}"
BT_MAC="${BT_MAC}"
BT_MACS="${BT_MACS}"
SNAPCAST_PORT="${SNAPCAST_PORT}"
ICECAST_PORT="8111"
PRESENCE_COOLDOWN="${PRESENCE_COOLDOWN}"
PRESENCE_ENABLED="${PRESENCE_ENABLED}"
INSTALL_DIR="${INSTALL_DIR}"
IFACE_AP="${IFACE_AP}"
IFACE_WAN="${IFACE_WAN}"
PICOPORT_ENABLED="${PICOPORT_ENABLED}"

# ── Logs centralisés ─────────────────────────────────────────────
# Niveau de filtre : DEBUG | INFO | WARN | ERROR
# DEBUG active les messages détaillés (boucles, pairs IPFS, frames caméra…)
LOG_LEVEL="${LOG_LEVEL}"
SOUNDSPOT_LOG="${SOUNDSPOT_LOG}"

# ── Clocher numérique ────────────────────────────────────────────
# Intervalle entre annonces quand aucun DJ ne diffuse (secondes).
# Les annonces et le bip 429.62 Hz ne peuvent pas être désactivés.
# Seul le mode horloge (coups de cloche) est configurable via le portail.
IDLE_ANNOUNCE_INTERVAL="900"
# CLOCK_MODE : "bells" (coups de cloche à l'heure) ou "silent" (heure vocale seule)
CLOCK_MODE="bells"

# ── Synthèse vocale Orpheus (si Picoport actif) ──────────────────
# Voix utilisée quand le nœud est connecté à la constellation UPlanet.
# pierre = voix masculine française | amelie = voix féminine française
# Le changement espeak → Orpheus est l'indicateur auditif de connexion.
ORPHEUS_VOICE="pierre"
ORPHEUS_PORT="5005"
