# SoundSpot Satellite — configuration
MASTER_HOST="${MASTER_HOST}"
TARGET_MASTER="${TARGET_MASTER}"
SPOT_NAME="${SPOT_NAME}"
SNAPCAST_PORT="${SNAPCAST_PORT}"
BT_MAC="${BT_MAC}"
BT_MACS="${BT_MACS}"
INSTALL_DIR="${INSTALL_DIR}"
SOUNDSPOT_USER="${SOUNDSPOT_USER}"
PICOPORT_ENABLED="${PICOPORT_ENABLED}"

# ── Logs centralisés ─────────────────────────────────────────────
LOG_LEVEL="${LOG_LEVEL}"
SOUNDSPOT_LOG="${SOUNDSPOT_LOG}"

# ── Synthèse vocale Orpheus (si Picoport actif) ──────────────────
# Les bouches (satellites) parlent avec la voix amelie par défaut.
ORPHEUS_VOICE="amelie"
ORPHEUS_PORT="5005"